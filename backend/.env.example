# SoliGuard Environment Configuration
# Copy this to .env and fill in your values

# =======================
# DEFAULT PROVIDER (GEMINI)
# =======================
GEMINI_API_KEY=your_gemini_api_key_here

# =======================
# BYOA PROVIDERS (Optional)
# =======================
# Uncomment and fill as needed

# Anthropic (Claude)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI (GPT)
# OPENAI_API_KEY=your_openai_key_here

# NVIDIA (NIM)
# NVIDIA_API_KEY=your_nvidia_key_here

# Qwen (Alibaba)
# QWEN_API_KEY=your_qwen_key_here

# Ollama (Local)
# OLLAMA_BASE_URL=http://localhost:11434

# Groq
# GROQ_API_KEY=your_groq_key_here

# Google Vertex AI
# GOOGLE_VERTEX_PROJECT=your_project_id
# GOOGLE_VERTEX_LOCATION=us-central1

# =======================
# BLOCKCHAIN APIs
# =======================
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Optional: Sourcify
# SOURCIFY_API_URL=https://repo.sourcify.dev

# =======================
# MULTI-CHAIN CONFIG
# =======================
# BSC (BscScan)
# BSCSCAN_API_KEY=your_bscscan_key_here

# Polygon (PolygonScan)
# POLYGONSCAN_API_KEY=your_polygonscan_key_here

# Arbitrum (Arbiscan)
# ARBISCAN_API_KEY=your_arbiscan_key_here

# Base (Basescan)
# BASESCAN_API_KEY=your_basescan_key_here

# =======================
# APPLICATION CONFIG
# =======================
ENVIRONMENT=development
PORT=8000
DEBUG=true

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =======================
# STORAGE (Optional)
# =======================
# DATABASE_URL=postgresql://user:password@localhost:5432/soliguard
# REDIS_URL=redis://localhost:6379/0

# =======================
# LOGGING
# =======================
LOG_LEVEL=INFO