        },
        "arb-mainnet": {
          "chain_id": 42161,
          "name": "Arbitrum Mainnet",
          "rpc_url": "",
          "ws_url": "",
          "api_url": "https://arb-mainnet.g.alchemy.com/v2"
        },
        "arb-goerli": {
          "chain_id": 421613,
          "name": "Arbitrum Goerli",
          "rpc_url": "",
          "ws_url": "",
          "api_url": "https://arb-goerli.g.alchemy.com/v2"
        },
        "opt-mainnet": {
          "chain_id": 10,
          "name": "Optimism Mainnet",
          "rpc_url": "",
          "ws_url": "",
          "api_url": "https://opt-mainnet.g.alchemy.com/v2"
        },
        "opt-goerli": {
          "chain_id": 420,
          "name": "Optimism Goerli",
          "rpc_url": "",
          "ws_url": "",
          "api_url": "https://opt-goerli.g.alchemy.com/v2"
        }
      },
      "features": {
        "sdk": true,
        "nft_api": true,
        "transact": true,
        "webhooks": true,
        "notify": true,
        "compute_units": true
      },
      "websocket": {
        "enabled": true,
        "reconnect": true,
        "reconnect_interval": 5000,
        "ping_interval": 30000
      }
    },
    "infura": {
      "name": "Infura",
      "description": "Web3 infrastructure platform",
      "enabled": false,
      "networks": {
        "mainnet": {
          "chain_id": 1,
          "name": "Ethereum Mainnet",
          "rpc_url": "",
          "ws_url": "",
          "api_url": "https://mainnet.infura.io/v3"
        },
        "goerli": {
          "chain_id": 5,
          "name": "Ethereum Goerli",
          "rpc_url": "",
          "ws_url": "",
          "api_url": "https://goerli.infura.io/v3"
        },
        "sepolia": {
          "chain_id": 11155111,
          "name": "Ethereum Sepolia",
          "rpc_url": "",
          "ws_url": "",
          "api_url": "https://sepolia.infura.io/v3"
        },
        "polygon": {
          "chain_id": 137,
          "name": "Polygon",
          "rpc_url": "",
          "ws_url": "",
          "api_url": "https://polygon-mainnet.infura.io/v3"
        },
        "arbitrum": {
          "chain_id": 42161,
          "name": "Arbitrum",
          "rpc_url": "",
          "ws_url": "",
          "api_url": "https://arbitrum-mainnet.infura.io/v3"
        },
        "optimism": {
          "chain_id": 10,
          "name": "Optimism",
          "rpc_url": "",
          "ws_url": "",
          "api_url": "https://optimism-mainnet.infura.io/v3"
        },
        "avalanche": {
          "chain_id": 43114,
          "name": "Avalanche",
          "rpc_url": "",
          "ws_url": "",
          "api_url": "https://avalanche-mainnet.infura.io/v3"
        }
      },
      "features": {
        "websocket": true,
        "archive_data": false,
        "debug_trace": false
      }
    },
    "ankr": {
      "name": "Ankr",
      "description": "Multi-chain RPC provider",
      "enabled": false,
      "networks": {
        "eth": {
          "chain_id": 1,
          "rpc_url": "https://rpc.ankr.com/eth",
          "ws_url": "wss://rpc.ankr.com/eth/ws"
        },
        "polygon": {
          "chain_id": 137,
          "rpc_url": "https://rpc.ankr.com/polygon",
          "ws_url": "wss://rpc.ankr.com/polygon/ws"
        },
        "bsc": {
          "chain_id": 56,
          "rpc_url": "https://rpc.ankr.com/bsc",
          "ws_url": "wss://rpc.ankr.com/bsc/ws"
        },
        "avalanche": {
          "chain_id": 43114,
          "rpc_url": "https://rpc.ankr.com/avalanche",
          "ws_url": "wss://rpc.ankr.com/avalanche/ws"
        },
        "arbitrum": {
          "chain_id": 42161,
          "rpc_url": "https://rpc.ankr.com/arbitrum",
          "ws_url": "wss://rpc.ankr.com/arbitrum/ws"
        },
        "optimism": {
          "chain_id": 10,
          "rpc_url": "https://rpc.ankr.com/optimism",
          "ws_url": "wss://rpc.ankr.com/optimism/ws"
        }
      },
      "features": {
        "free_tier": true,
        "websocket": true
      }
    },
    "public_rpc": {
      "name": "Public RPC",
      "description": "Public Ethereum RPC endpoints",
      "enabled": false,
      "networks": {
        "mainnet": {
          "chain_id": 1,
          "rpc_urls": [
            "https://cloudflare-eth.com",
            "https://eth.public-rpc.com"
          ]
        },
        "goerli": {
          "chain_id": 5,
          "rpc_urls": [
            "https://goerli.public-rpc.com"
          ]
        }
      },
      "rate_limits": {
        "requests_per_second": 10,
        "burst": 20
      },
      "features": {
        "batch_requests": true,
        "logging": false
      }
    }
  },
  "rate_limiting": {
    "enabled": true,
    "strategy": "token_bucket",
    "global": {
      "requests_per_minute": 60,
      "burst_size": 100
    },
    "by_provider": {
      "etherscan": {
        "requests_per_second": 5,
        "burst": 10
      },
      "alchemy": {
        "requests_per_second": 50,
        "burst": 100
      },
      "infura": {
        "requests_per_second": 50,
        "burst": 100
      }
    },
    "by_network": {
      "mainnet": {
        "multiplier": 1.0
      },
      "testnet": {
        "multiplier": 0.5
      }
    }
  },
  "caching": {
    "enabled": true,
    "backend": "memory",
    "default_ttl": 300,
    "by_endpoint": {
      "get_abi": 3600,
      "get_source_code": 3600,
      "balance": 60,
      "transaction": 120,
      "block": 300
    },
    "invalidation": {
      "on_new_block": true,
      "on_transaction": false
    }
  },
  "failover": {
    "enabled": true,
    "primary": "etherscan",
    "secondary": "alchemy",
    "tertiary": "public_rpc",
    "health_check": {
      "enabled": true,
      "interval": 60,
      "timeout": 10,
      "unhealthy_threshold": 3,
      "healthy_threshold": 2
    }
  },
  "retry": {
    "enabled": true,
    "max_attempts": 3,
    "backoff": {
      "strategy": "exponential",
      "initial_delay": 1000,
      "max_delay": 10000,
      "multiplier": 2.0
    },
    "retryable_errors": [
      "rate_limit",
      "timeout",
      "503",
      "502",
      "429"
    ]
  },
  "monitoring": {
    "enabled": true,
    "metrics": {
      "request_count": true,
      "request_duration": true,
      "error_count": true,
      "rate_limit_hits": true,
      "cache_hits": true,
      "cache_misses": true
    },
    "alerting": {
      "enabled": false,
      "error_rate_threshold": 0.05,
      "latency_threshold": 5000
    }
  }
}