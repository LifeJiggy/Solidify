{
  "providers": {
    "etherscan": {
      "name": "Etherscan",
      "description": "Ethereum blockchain explorer and API",
      "enabled": true,
      "networks": {
        "mainnet": {
          "chain_id": 1,
          "api_url": "https://api.etherscan.io/api",
          "web_url": "https://etherscan.io",
          "rate_limit": 5,
          "rate_limit_period": 1000
        },
        "goerli": {
          "chain_id": 5,
          "api_url": "https://api-goerli.etherscan.io/api",
          "web_url": "https://goerli.etherscan.io",
          "rate_limit": 5,
          "rate_limit_period": 1000
        },
        "sepolia": {
          "chain_id": 11155111,
          "api_url": "https://api-sepolia.etherscan.io/api",
          "web_url": "https://sepolia.etherscan.io",
          "rate_limit": 5,
          "rate_limit_period": 1000
        }
      },
      "api_modules": {
        "account": {
          "enabled": true,
          "endpoints": ["balance", "txlist", "txlistinternal", "tokenlist", "tokenbalance"],
          "rate_limit": 5
        },
        "contract": {
          "enabled": true,
          "endpoints": ["getabi", "getcontractsourcecode", "verifysourcecode"],
          "rate_limit": 10
        },
        "transaction": {
          "enabled": true,
          "endpoints": ["getstatus", "gettxreceiptstatus"],
          "rate_limit": 5
        },
        "block": {
          "enabled": true,
          "endpoints": ["getblocknobytime", "getblockcountdown", "getblockbytimestamp"],
          "rate_limit": 5
        },
        "logs": {
          "enabled": true,
          "endpoints": ["getLogs", "getTokenEvents"],
          "rate_limit": 10
        },
        "stats": {
          "enabled": true,
          "endpoints": ["ethsupply", "ethprice"],
          "rate_limit": 10
        },
        "proxy": {
          "enabled": true,
          "endpoints": ["eth_blockNumber", "eth_getBlockByNumber", "eth_getTransactionByHash"],
          "rate_limit": 20
        }
      },
      "cache": {
        "enabled": true,
        "ttl": 300,
        "max_size": 1000
      },
      "auth": {
        "type": "api_key",
        "key_header": "X-API-Key",
        "required": false
      }
    },
    "polygonscan": {
      "name": "Polygonscan",
      "description": "Polygon blockchain explorer and API",
      "enabled": true,
      "networks": {
        "mainnet": {
          "chain_id": 137,
          "api_url": "https://api.polygonscan.com/api",
          "web_url": "https://polygonscan.com",
          "rate_limit": 5,
          "rate_limit_period": 1000
        },
        "mumbai": {
          "chain_id": 80001,
          "api_url": "https://api-mumbai.polygonscan.com/api",
          "web_url": "https://mumbai.polygonscan.com",
          "rate_limit": 5,
          "rate_limit_period": 1000
        }
      },
      "api_modules": {
        "account": {
          "enabled": true,
          "endpoints": ["balance", "txlist", "tokenlist"]
        },
        "contract": {
          "enabled": true,
          "endpoints": ["getabi", "getcontractsourcecode"]
        },
        "transaction": {
          "enabled": true,
          "endpoints": ["getstatus", "gettxreceiptstatus"]
        },
        "proxy": {
          "enabled": true,
          "endpoints": ["eth_blockNumber", "eth_getBlockByNumber"]
        }
      }
    },
    "bscscan": {
      "name": "BscScan",
      "description": "BNB Smart Chain explorer and API",
      "enabled": true,
      "networks": {
        "mainnet": {
          "chain_id": 56,
          "api_url": "https://api.bscscan.com/api",
          "web_url": "https://bscscan.com",
          "rate_limit": 5,
          "rate_limit_period": 1000
        },
        "testnet": {
          "chain_id": 97,
          "api_url": "https://api-testnet.bscscan.com/api",
          "web_url": "https://testnet.bscscan.com",
          "rate_limit": 5,
          "rate_limit_period": 1000
        }
      },
      "api_modules": {
        "account": {
          "enabled": true,
          "endpoints": ["balance", "txlist"]
        },
        "contract": {
          "enabled": true,
          "endpoints": ["getabi", "getcontractsourcecode"]
        }
      }
    },
    "sourcify": {
      "name": "Sourcify",
      "description": "Smart contract source code repository",
      "enabled": true,
      "servers": {
        "production": {
          "url": "https://sourcify.dev/server",
          "repo_url": "https://repo.sourcify.dev",
          "rate_limit": 10,
          "timeout": 30
        },
        "staging": {
          "url": "https://sourcify.staging-amoy.bot.tax",
          "repo_url": "https://repo.sourcify.staging-amoy.bot.tax",
          "rate_limit": 10,
          "timeout": 30
        }
      },
      "features": {
        "auto_match": true,
        "partial_match": true,
        "metadata_download": true,
        "source_download": true
      },
      "chain_ids": [1, 5, 11155111, 137, 80001, 56, 97, 43114, 43113, 42161, 421613, 10, 420],
      "cache": {
        "enabled": true,
        "ttl": 3600,
        "max_size": 500
      }
    },
    "alchemy": {
      "name": "Alchemy",
      "description": "Web3 development platform and API",
      "enabled": false,
      "networks": {
        "eth-mainnet": {
