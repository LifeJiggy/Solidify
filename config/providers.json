          "rpc_url": "",
          "ws_url": "",
          "api_url": "https://eth-mainnet.g.alchemy.com/v2",
          "max_redaneunits": 50,
          "max_compute_units": 264
        },
        "eth-goerli": {
          "chain_id": 5,
          "name": "Ethereum Goerli",
          "rpc_url": "",
          "ws_url": "",
          "api_url": "https://eth-goerli.g.alchemy.com/v2"
        },
        "eth-sepolia": {
          "chain_id": 11155111,
          "name": "Ethereum Sepolia",
          "rpc_url": "",
          "ws_url": "",
          "api_url": "https://eth-sepolia.g.alchemy.com/v2"
        },
        "polygon-mainnet": {
          "chain_id": 137,
          "name": "Polygon Mainnet",
          "rpc_url": "",
          "ws_url": "",
          "api_url": "https://polygon-mainnet.g.alchemy.com/v2"
        },
        "polygon-mumbai": {
          "chain_id": 80001,
          "name": "Polygon Mumbai",
          "rpc_url": "",
